#~ msgstr ""
#~ "Διάλογος Select Cases. Επιλέξτε αν θα χρησιμοποιηθούν όλες οι "
#~ "περιπτώσεις, περιπτώσεις που ικανοποιούν συνθήκη, τυχαίο δείγμα, χρονικό "
#~ "εύρος ή φιλτραρισμένες περιπτώσεις. Ελέγξτε την επιλογή output πριν από "
#~ "OK ή Paste."

#~ msgid ""
#~ "Split File dialog. Choose whether output is analyzed together or by "
#~ "groups, then move grouping variables into the Groups Based on list."
#~ msgstr ""
#~ "Διάλογος Split File. Επιλέξτε αν τα αποτελέσματα θα αναλυθούν μαζί ή ανά "
#~ "ομάδες και μετά μετακινήστε μεταβλητές ομαδοποίησης στη λίστα Groups "
#~ "Based on."

#~ msgid ""
#~ "Weight Cases dialog. Choose Do not weight cases or Weight cases by, then "
#~ "move a numeric frequency or weight variable to the Frequency Variable "
#~ "field."
#~ msgstr ""
#~ "Διάλογος Weight Cases. Επιλέξτε Do not weight cases ή Weight cases by και "
#~ "μετά μετακινήστε αριθμητική μεταβλητή συχνότητας ή βάρους στο πεδίο "
#~ "Frequency Variable."

#~ msgid ""
#~ "Value Labels dialog. Enter a data value and its label, choose Add, "
#~ "Change, or Remove, then OK. This is used for categorical code labels such "
#~ "as 0 equals No and 1 equals Yes."
#~ msgstr ""
#~ "Διάλογος Value Labels. Πληκτρολογήστε τιμή δεδομένων και την ετικέτα της, "
#~ "επιλέξτε Add, Change ή Remove και μετά OK. Χρησιμοποιείται για ετικέτες "
#~ "κατηγορικών κωδικών, όπως 0 ίσον Όχι και 1 ίσον Ναι."

#~ msgid ""
#~ "Missing Values dialog. Choose no missing values, discrete missing values, "
#~ "or a range plus one optional discrete value, then enter the missing-value "
#~ "definitions."
#~ msgstr ""
#~ "Διάλογος Missing Values. Επιλέξτε χωρίς ελλείπουσες τιμές, διακριτές "
#~ "ελλείπουσες τιμές ή εύρος με μία προαιρετική διακριτή τιμή και μετά "
#~ "πληκτρολογήστε τους ορισμούς ελλειπουσών τιμών."

#~ msgid ""
#~ "Variable Type dialog. Choose Numeric, Comma, Dot, Scientific notation, "
#~ "Date, Dollar, Custom Currency, or String. Review width and decimals when "
#~ "available."
#~ msgstr ""
#~ "Διάλογος Variable Type. Επιλέξτε Numeric, Comma, Dot, Scientific "
#~ "notation, Date, Dollar, Custom Currency ή String. Ελέγξτε width και "
#~ "decimals όταν είναι διαθέσιμα."

#~ msgid ""
#~ "Read Excel File dialog. Confirm the worksheet, variable-name row, cell "
#~ "range, and import settings before OK."
#~ msgstr ""
#~ "Διάλογος Read Excel File. Επιβεβαιώστε worksheet, γραμμή ονομάτων "
#~ "μεταβλητών, περιοχή κελιών και ρυθμίσεις εισαγωγής πριν από OK."

#~ msgid ""
#~ "Text Import Wizard. Move through the wizard steps to define delimiters or "
#~ "fixed widths, variable names, data formats, and import range."
#~ msgstr ""
#~ "Text Import Wizard. Μετακινηθείτε στα βήματα του οδηγού για να ορίσετε "
#~ "διαχωριστικά ή σταθερά πλάτη, ονόματα μεταβλητών, μορφές δεδομένων και "
#~ "εύρος εισαγωγής."

#~ msgid ""
#~ "Database Wizard. Choose the data source, select tables and fields, define "
#~ "joins or filters, and review variable definitions before import."
#~ msgstr ""
#~ "Database Wizard. Επιλέξτε την πηγή δεδομένων, επιλέξτε πίνακες και πεδία, "
#~ "ορίστε joins ή φίλτρα και ελέγξτε τους ορισμούς μεταβλητών πριν από την "
#~ "εισαγωγή."

#~ msgid ""
#~ "Frequencies: Συχνότητες. Counts values and percentages for categorical or "
#~ "discrete variables."
#~ msgstr ""
#~ "Frequencies: Συχνότητες. Μετρά τιμές και ποσοστά για κατηγορικές ή "
#~ "διακριτές μεταβλητές."

#~ msgid ""
#~ "Descriptives: Περιγραφικά στατιστικά. Reports mean, standard deviation, "
#~ "minimum, maximum, and similar summaries."
#~ msgstr ""
#~ "Descriptives: Περιγραφικά στατιστικά. Αναφέρει μέσο όρο, τυπική απόκλιση, "
#~ "ελάχιστο, μέγιστο και παρόμοιες συνόψεις."

#~ msgid ""
#~ "Crosstabs: Πίνακες συνάφειας. Compares categories of two or more "
#~ "variables in a contingency table."
#~ msgstr ""
#~ "Crosstabs: Πίνακες συνάφειας. Συγκρίνει κατηγορίες δύο ή περισσότερων "
#~ "μεταβλητών σε πίνακα συνάφειας."

#~ msgid ""
#~ "Regression: Παλινδρόμηση. Models an outcome variable from one or more "
#~ "predictors."
#~ msgstr ""
#~ "Regression: Παλινδρόμηση. Μοντελοποιεί μεταβλητή έκβασης από έναν ή "
#~ "περισσότερους προβλεπτικούς παράγοντες."

#~ msgid "Correlations: Συσχετίσεις. Measures association between variables."
#~ msgstr "Correlations: Συσχετίσεις. Μετρά τη συσχέτιση μεταξύ μεταβλητών."

#~ msgid "Compare Means: Σύγκριση μέσων. Compares averages across groups."
#~ msgstr ""
#~ "Compare Means: Σύγκριση μέσων. Συγκρίνει μέσους όρους μεταξύ ομάδων."

#~ msgid ""
#~ "Explore: Διερεύνηση. Reviews distributions, outliers, and group summaries."
#~ msgstr ""
#~ "Explore: Διερεύνηση. Ελέγχει κατανομές, ακραίες τιμές και συνόψεις ομάδων."

#~ msgid ""
#~ "Nonparametric Tests: Μη παραμετρικοί έλεγχοι. Runs tests that do not "
#~ "assume normal distributions."
#~ msgstr ""
#~ "Nonparametric Tests: Μη παραμετρικοί έλεγχοι. Εκτελεί ελέγχους που δεν "
#~ "προϋποθέτουν κανονικές κατανομές."

#~ msgid ""
#~ "Value Labels: Ετικέτες τιμών. Human-readable labels for coded values."
#~ msgstr ""
#~ "Value Labels: Ετικέτες τιμών. Αναγνώσιμες ετικέτες για κωδικοποιημένες "
#~ "τιμές."

#~ msgid ""
#~ "Missing Values: Ελλείπουσες τιμές. User-defined values that SPSS treats "
#~ "as missing."
#~ msgstr ""
#~ "Missing Values: Ελλείπουσες τιμές. Τιμές ορισμένες από τον χρήστη που το "
#~ "SPSS αντιμετωπίζει ως ελλείπουσες."

