msgid "Button"
msgstr "Κουμπί"

msgid "Text box"
msgstr "Πλαίσιο κειμένου"

msgid "Checkbox"
msgstr "Πλαίσιο επιλογής"

msgid "Radio button"
msgstr "Κουμπί επιλογής"

msgid "Dropdown menu"
msgstr "Αναπτυσσόμενο μενού"

msgid "List"
msgstr "Λίστα"

msgid "List item"
msgstr "Στοιχείο λίστας"

msgid "Tree item"
msgstr "Στοιχείο δέντρου"

msgid "IBM SPSS Statistics"
msgstr "IBM SPSS Statistics"

msgid "Press Alt+Down Arrow or Space to open the dropdown menu."
msgstr "Πατήστε Alt+Κάτω βέλος ή Space για να ανοίξετε το αναπτυσσόμενο μενού."

msgid "Press Space or Enter to activate."
msgstr "Πατήστε Space ή Enter για ενεργοποίηση."

msgid "Type text or use editing commands."
msgstr "Πληκτρολογήστε κείμενο ή χρησιμοποιήστε εντολές επεξεργασίας."

msgid "Press Space to change the selection."
msgstr "Πατήστε Space για αλλαγή της επιλογής."

msgid "Use arrow keys to move through items."
msgstr "Χρησιμοποιήστε τα βελάκια για μετακίνηση στα στοιχεία."

msgid "Current value {value}"
msgstr "Τρέχουσα τιμή {value}"

msgid "Move to the SPSS Output Viewer or describe how to use it"
msgstr "Μετάβαση στην Προβολή αποτελεσμάτων SPSS ή περιγραφή χρήσης της"

msgid "Move to SPSS Data View"
msgstr "Μετάβαση στο Data View του SPSS"

msgid "Move to SPSS Overview"
msgstr "Μετάβαση στην Επισκόπηση SPSS"

msgid "Move to SPSS Variable View"
msgstr "Μετάβαση στο Variable View του SPSS"

msgid "Move to the SPSS menu bar"
msgstr "Μετάβαση στη γραμμή μενού του SPSS"

msgid "Move to the SPSS Syntax Editor"
msgstr "Μετάβαση στον Syntax Editor του SPSS"

msgid "Move to or describe SPSS Chart Builder"
msgstr "Μετάβαση ή περιγραφή του Chart Builder του SPSS"

msgid "Describe the current SPSS pane"
msgstr "Περιγραφή της τρέχουσας περιοχής SPSS"

msgid ""
"Current SPSS pane could not be identified. Use Tab, Shift+Tab, or the SPSS "
"Window menu to move between open windows."
msgstr ""
"Η τρέχουσα περιοχή SPSS δεν αναγνωρίστηκε. Χρησιμοποιήστε Tab, Shift+Tab ή "
"το μενού Window του SPSS για μετακίνηση μεταξύ ανοιχτών παραθύρων."

msgid "Describe SPSS menus and what each menu contains"
msgstr "Περιγραφή των μενού του SPSS και του τι περιέχουν"

msgid "Describe SPSS output accessibility and export options"
msgstr "Περιγραφή προσβασιμότητας αποτελεσμάτων SPSS και επιλογών εξαγωγής"

msgid "Describe where you are in SPSS and what is available"
msgstr "Περιγραφή του πού βρίσκεστε στο SPSS και τι είναι διαθέσιμο"

msgid "No SPSS context is available at the current focus."
msgstr "Δεν υπάρχει διαθέσιμο πλαίσιο SPSS στην τρέχουσα εστίαση."

msgid "Read the current SPSS menu path"
msgstr "Ανάγνωση της τρέχουσας διαδρομής μενού SPSS"

msgid "No SPSS menu path is available at the current focus."
msgstr "Δεν υπάρχει διαθέσιμη διαδρομή μενού SPSS στην τρέχουσα εστίαση."

msgid "List the items in the current SPSS menu or submenu"
msgstr "Λίστα στοιχείων του τρέχοντος μενού ή υπομενού SPSS"

msgid "No open SPSS menu or submenu was found at the current focus."
msgstr "Δεν βρέθηκε ανοιχτό μενού ή υπομενού SPSS στην τρέχουσα εστίαση."

msgid "Describe the current SPSS dialog"
msgstr "Περιγραφή του τρέχοντος διαλόγου SPSS"

msgid "No SPSS dialog help is available at the current focus."
msgstr "Δεν υπάρχει διαθέσιμη βοήθεια διαλόγου SPSS στην τρέχουσα εστίαση."

msgid "Read every field and button in the current SPSS dialog"
msgstr "Ανάγνωση κάθε πεδίου και κουμπιού του τρέχοντος διαλόγου SPSS"

msgid "No SPSS dialog was found at the current focus."
msgstr "Δεν βρέθηκε διάλογος SPSS στην τρέχουσα εστίαση."

msgid "Summarize SPSS dialog variable lists"
msgstr "Σύνοψη λιστών μεταβλητών διαλόγου SPSS"

msgid ""
"No source or target variable lists were found in the current SPSS dialog."
msgstr ""
"Δεν βρέθηκαν λίστες μεταβλητών προέλευσης ή στόχου στον τρέχοντα διάλογο "
"SPSS."

msgid "Read the current SPSS table summary"
msgstr "Ανάγνωση σύνοψης του τρέχοντος πίνακα SPSS"

msgid "No SPSS table summary is available at the current focus."
msgstr "Δεν υπάρχει διαθέσιμη σύνοψη πίνακα SPSS στην τρέχουσα εστίαση."

msgid "Read all available properties for the current SPSS variable"
msgstr "Ανάγνωση όλων των διαθέσιμων ιδιοτήτων της τρέχουσας μεταβλητής SPSS"

msgid "No SPSS variable row summary is available at the current focus."
msgstr ""
"Δεν υπάρχει διαθέσιμη σύνοψη γραμμής μεταβλητής SPSS στην τρέχουσα εστίαση."

msgid "Summarize the SPSS Output Viewer outline"
msgstr "Σύνοψη του περιγράμματος στο SPSS Output Viewer"

msgid "No SPSS output outline was found."
msgstr "Δεν βρέθηκε περίγραμμα αποτελεσμάτων SPSS."

msgid "Read current SPSS output table row and column"
msgstr "Ανάγνωση τρέχουσας γραμμής και στήλης πίνακα αποτελεσμάτων SPSS"

msgid ""
"No SPSS output table row or column summary is available at the current focus."
msgstr ""
"Δεν υπάρχει διαθέσιμη σύνοψη γραμμής ή στήλης πίνακα αποτελεσμάτων SPSS στην "
"τρέχουσα εστίαση."

msgid "Copy a readable SPSS output summary to the clipboard"
msgstr "Αντιγραφή αναγνώσιμης σύνοψης αποτελέσματος SPSS στο πρόχειρο"

msgid "No readable SPSS output summary is available to copy."
msgstr ""
"Δεν υπάρχει διαθέσιμη αναγνώσιμη σύνοψη αποτελέσματος SPSS για αντιγραφή."

msgid "Copied readable SPSS output summary to the clipboard."
msgstr "Η αναγνώσιμη σύνοψη αποτελέσματος SPSS αντιγράφηκε στο πρόχειρο."

msgid ""
"Clipboard copy is unavailable. The readable SPSS output summary was written "
"to the NVDA log."
msgstr ""
"Η αντιγραφή στο πρόχειρο δεν είναι διαθέσιμη. Η αναγνώσιμη σύνοψη "
"αποτελέσματος SPSS γράφτηκε στο log του NVDA."

msgid "Copy the current SPSS output table row to the clipboard"
msgstr "Αντιγραφή της τρέχουσας γραμμής πίνακα αποτελεσμάτων SPSS στο πρόχειρο"

msgid "No SPSS output table row is available to copy."
msgstr "Δεν υπάρχει διαθέσιμη γραμμή πίνακα αποτελεσμάτων SPSS για αντιγραφή."

msgid "Copied current SPSS output table row to the clipboard."
msgstr "Η τρέχουσα γραμμή πίνακα αποτελεσμάτων SPSS αντιγράφηκε στο πρόχειρο."

msgid ""
"Clipboard copy is unavailable. The current SPSS output table row was written "
"to the NVDA log."
msgstr ""
"Η αντιγραφή στο πρόχειρο δεν είναι διαθέσιμη. Η τρέχουσα γραμμή πίνακα "
"αποτελεσμάτων SPSS γράφτηκε στο log του NVDA."

msgid "Read Greek and English SPSS statistics glossary"
msgstr "Ανάγνωση ελληνικού και αγγλικού γλωσσαρίου στατιστικής SPSS"

msgid "{en} ({el}): {enDesc} {elDesc}"
msgstr "{en} ({el}): {enDesc} {elDesc}"

msgid "Read the current SPSS tab and table context"
msgstr "Ανάγνωση της τρέχουσας καρτέλας και του πλαισίου πίνακα στο SPSS"

msgid "No SPSS tab or table context is available at the current focus."
msgstr ""
"Δεν υπάρχει διαθέσιμη καρτέλα ή πλαίσιο πίνακα SPSS στην τρέχουσα εστίαση."

msgid "Read the current SPSS output item or selected output block"
msgstr ""
"Ανάγνωση του τρέχοντος στοιχείου αποτελέσματος ή επιλεγμένου block "
"αποτελέσματος SPSS"

msgid ""
"No readable SPSS output item was found at the current focus. Try moving to "
"the Output Viewer outline or document area first."
msgstr ""
"Δεν βρέθηκε αναγνώσιμο στοιχείο αποτελέσματος SPSS στην τρέχουσα εστίαση. "
"Δοκιμάστε πρώτα να μετακινηθείτε στο outline ή στην περιοχή εγγράφου της "
"Προβολής αποτελεσμάτων."

msgid "Read the current SPSS Data View cell with row, variable, and value"
msgstr ""
"Ανάγνωση του τρέχοντος κελιού στο Data View με γραμμή, μεταβλητή και τιμή"

msgid "No SPSS data cell information is available at the current focus."
msgstr ""
"Δεν υπάρχουν διαθέσιμες πληροφορίες κελιού δεδομένων SPSS στην τρέχουσα "
"εστίαση."

msgid "Read the current SPSS Variable View definition cell"
msgstr "Ανάγνωση του τρέχοντος κελιού ορισμού στο Variable View"

msgid ""
"No SPSS variable definition information is available at the current focus."
msgstr ""
"Δεν υπάρχουν διαθέσιμες πληροφορίες ορισμού μεταβλητής SPSS στην τρέχουσα "
"εστίαση."

msgid ""
"Cycle the spoken language for SPSS content between automatic, English, and "
"Greek"
msgstr "Εναλλαγή γλώσσας εκφώνησης περιεχομένου SPSS μεταξύ αυτόματης, αγγλικών και ελληνικών"

msgid ""
"SPSS content language set to automatic, following the SPSS interface "
"language."
msgstr "Η γλώσσα περιεχομένου SPSS ορίστηκε σε αυτόματη, ακολουθώντας τη γλώσσα διεπαφής του SPSS."

msgid "SPSS content language set to English."
msgstr "Η γλώσσα περιεχομένου SPSS ορίστηκε σε αγγλικά."

msgid "SPSS content language set to Greek."
msgstr "Η γλώσσα περιεχομένου SPSS ορίστηκε σε ελληνικά."

msgid "List SPSS accessibility add-on shortcuts"
msgstr "Λίστα συντομεύσεων του πρόσθετου προσβασιμότητας SPSS"

msgid "NVDA+Control+Alt+O: Output Viewer."
msgstr "NVDA+Control+Alt+O: Προβολή αποτελεσμάτων."

msgid "NVDA+Control+Alt+D: Data View."
msgstr "NVDA+Control+Alt+D: Προβολή δεδομένων."

msgid "NVDA+Control+Alt+U: Overview."
msgstr "NVDA+Control+Alt+U: Επισκόπηση."

msgid "NVDA+Control+Alt+V: Variable View."
msgstr "NVDA+Control+Alt+V: Προβολή μεταβλητών."

msgid "NVDA+Control+Alt+M: Menu bar."
msgstr "NVDA+Control+Alt+M: Γραμμή μενού."

msgid "NVDA+Control+Alt+S: Syntax Editor."
msgstr "NVDA+Control+Alt+S: Επεξεργαστής σύνταξης."

msgid "NVDA+Control+Alt+C: Chart Builder."
msgstr "NVDA+Control+Alt+C: Chart Builder."

msgid "NVDA+Control+Alt+W: where am I in SPSS."
msgstr "NVDA+Control+Alt+W: πού βρίσκομαι στο SPSS."

msgid "NVDA+Control+Alt+T: read current tab and table context."
msgstr "NVDA+Control+Alt+T: ανάγνωση τρέχουσας καρτέλας και πλαισίου πίνακα."

msgid "NVDA+Control+Alt+Shift+O: read current output item."
msgstr "NVDA+Control+Alt+Shift+O: ανάγνωση τρέχοντος αποτελέσματος."

msgid "NVDA+Control+Alt+Shift+D: read current data cell."
msgstr "NVDA+Control+Alt+Shift+D: ανάγνωση τρέχοντος κελιού δεδομένων."

msgid "NVDA+Control+Alt+Shift+V: read current variable definition."
msgstr "NVDA+Control+Alt+Shift+V: ανάγνωση τρέχοντος ορισμού μεταβλητής."

msgid "NVDA+Control+Alt+Shift+N: read current menu path."
msgstr "NVDA+Control+Alt+Shift+N: ανάγνωση τρέχουσας διαδρομής μενού."

msgid "NVDA+Control+Alt+Shift+Q: list items in the current menu or submenu."
msgstr "NVDA+Control+Alt+Shift+Q: λίστα στοιχείων του τρέχοντος μενού ή υπομενού."

msgid "NVDA+Control+Alt+Shift+I: describe current dialog."
msgstr "NVDA+Control+Alt+Shift+I: περιγραφή τρέχοντος διαλόγου."

msgid ""
"NVDA+Control+Alt+Shift+K: read every field and button in the current dialog."
msgstr "NVDA+Control+Alt+Shift+K: ανάγνωση κάθε πεδίου και κουμπιού του τρέχοντος διαλόγου."

msgid "NVDA+Control+Alt+Shift+L: summarize dialog variable lists."
msgstr "NVDA+Control+Alt+Shift+L: σύνοψη λιστών μεταβλητών διαλόγου."

msgid "NVDA+Control+Alt+Shift+T: read table summary."
msgstr "NVDA+Control+Alt+Shift+T: ανάγνωση σύνοψης πίνακα."

msgid "NVDA+Control+Alt+Shift+R: read all properties for current variable."
msgstr ""
"NVDA+Control+Alt+Shift+R: ανάγνωση όλων των ιδιοτήτων της τρέχουσας "
"μεταβλητής."

msgid "NVDA+Control+Alt+Shift+U: summarize Output Viewer outline."
msgstr "NVDA+Control+Alt+Shift+U: σύνοψη περιγράμματος Output Viewer."

msgid "NVDA+Control+Alt+Shift+Y: read output table row and column."
msgstr ""
"NVDA+Control+Alt+Shift+Y: ανάγνωση γραμμής και στήλης πίνακα αποτελεσμάτων."

msgid "NVDA+Control+Alt+Shift+C: copy readable output summary."
msgstr "NVDA+Control+Alt+Shift+C: αντιγραφή αναγνώσιμης σύνοψης αποτελέσματος."

msgid "NVDA+Control+Alt+Shift+X: copy current output table row."
msgstr ""
"NVDA+Control+Alt+Shift+X: αντιγραφή τρέχουσας γραμμής πίνακα αποτελεσμάτων."

msgid "NVDA+Control+Alt+Shift+F: read Greek and English statistics glossary."
msgstr ""
"NVDA+Control+Alt+Shift+F: ανάγνωση ελληνικού και αγγλικού γλωσσαρίου "
"στατιστικής."

msgid "NVDA+Control+Alt+Shift+P: describe current pane."
msgstr "NVDA+Control+Alt+Shift+P: περιγραφή τρέχουσας περιοχής."

msgid "NVDA+Control+Alt+Shift+M: describe SPSS menus."
msgstr "NVDA+Control+Alt+Shift+M: περιγραφή μενού SPSS."

msgid ""
"NVDA+Control+Alt+Shift+E: describe output accessibility and export options."
msgstr ""
"NVDA+Control+Alt+Shift+E: περιγραφή προσβασιμότητας αποτελεσμάτων και "
"επιλογών εξαγωγής."

msgid "NVDA+Control+Alt+Shift+J: cycle spoken language for SPSS content."
msgstr "NVDA+Control+Alt+Shift+J: εναλλαγή γλώσσας εκφώνησης περιεχομένου SPSS."

msgid "NVDA+Control+Alt+Shift+B: toggle beginner or concise SPSS guidance."
msgstr ""
"NVDA+Control+Alt+Shift+B: εναλλαγή αναλυτικής ή σύντομης καθοδήγησης SPSS."

msgid "NVDA+Control+Alt+Shift+A: toggle automatic table cell announcements."
msgstr ""
"NVDA+Control+Alt+Shift+A: εναλλαγή αυτόματων ανακοινώσεων κελιών πίνακα."

msgid ""
"NVDA+Control+Alt+Shift+G: log the current SPSS accessibility object for "
"troubleshooting."
msgstr ""
"NVDA+Control+Alt+Shift+G: καταγραφή του τρέχοντος αντικειμένου "
"προσβασιμότητας SPSS για αντιμετώπιση προβλημάτων."

msgid "NVDA+Control+Alt+Shift+H: list these shortcuts."
msgstr "NVDA+Control+Alt+Shift+H: λίστα αυτών των συντομεύσεων."

msgid "Toggle beginner or concise SPSS guidance"
msgstr "Εναλλαγή αναλυτικής ή σύντομης καθοδήγησης SPSS"

msgid "SPSS guidance set to beginner detail."
msgstr "Η καθοδήγηση SPSS ορίστηκε σε αναλυτική μορφή."

msgid "SPSS guidance set to concise announcements."
msgstr "Η καθοδήγηση SPSS ορίστηκε σε σύντομες ανακοινώσεις."

msgid "Toggle automatic SPSS table cell announcements"
msgstr "Εναλλαγή αυτόματων ανακοινώσεων κελιών πίνακα SPSS"

msgid "Automatic SPSS table cell announcements on."
msgstr "Οι αυτόματες ανακοινώσεις κελιών πίνακα SPSS είναι ενεργές."

msgid "Automatic SPSS table cell announcements off."
msgstr "Οι αυτόματες ανακοινώσεις κελιών πίνακα SPSS είναι ανενεργές."

msgid "Log the current SPSS accessibility object for troubleshooting"
msgstr ""
"Καταγραφή του τρέχοντος αντικειμένου προσβασιμότητας SPSS για αντιμετώπιση "
"προβλημάτων"

msgid "Current SPSS accessibility object was written to the NVDA log."
msgstr "Το τρέχον αντικείμενο προσβασιμότητας SPSS γράφτηκε στο log του NVDA."

msgid "Window {name}"
msgstr "Παράθυρο {name}"

msgid "Pane {pane}"
msgstr "Περιοχή {pane}"

msgid "Press Enter or Space to activate."
msgstr "Πατήστε Enter ή Space για ενεργοποίηση."

msgid ""
"Use arrow keys to move, Space to select, Control+C to copy a variable, and "
"Shift+F10 for context commands."
msgstr ""
"Χρησιμοποιήστε τα βελάκια για μετακίνηση, Space για επιλογή, Control+C για "
"αντιγραφή μεταβλητής και Shift+F10 για εντολές περιβάλλοντος."

msgid "Use arrow keys to move and Space to select items."
msgstr ""
"Χρησιμοποιήστε τα βελάκια για μετακίνηση και Space για επιλογή στοιχείων."

msgid "Use arrow keys to move in the table."
msgstr "Χρησιμοποιήστε τα βελάκια για μετακίνηση στον πίνακα."

msgid ""
"Paste a copied variable here with Control+V, or open context commands with "
"Shift+F10."
msgstr ""
"Επικολλήστε εδώ μια αντιγραμμένη μεταβλητή με Control+V ή ανοίξτε εντολές "
"περιβάλλοντος με Shift+F10."

